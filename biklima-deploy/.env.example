# ⚠️ انسخ هذا الملف إلى .env وعبّئ القيم

NODE_ENV=production
PORT=3000

# مفتاح الجلسة (اختر سلسلة عشوائية طويلة)
SESSION_SECRET=change_this_to_random_secret_string_here

# إعدادات البريد الإلكتروني (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
