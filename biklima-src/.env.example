# ─────────────────────────────────────────────
#  بكلمة — Bikalima  |  Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── General ───────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Session ───────────────────────────────────
# Generate a random 64-char string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# ── Database ──────────────────────────────────
# PostgreSQL connection string (Neon.tech, Supabase, or self-hosted)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/biklima?sslmode=require

# ── SMTP / Email ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
# Optional — defaults to "بكلمة" <SMTP_USER>
SMTP_FROM="بكلمة" <info@bikalima.com>

# ── Zoom ──────────────────────────────────────
# Full Zoom join link shown in consultation confirmation emails
ZOOM_MEETING_URL=https://scheduler.zoom.us/suhaib-ahmad-x9pyfc
